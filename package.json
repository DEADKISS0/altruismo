{
  "name": "altruismo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:css": "stylelint \"**/*.css\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --max-workers=2",
    "test:coverage": "jest --coverage",
    "test:a11y": "jest --testPathPattern=a11y",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse": "lighthouse-ci autorun --config=../lighthouse-budget.json",
    "bundle:analyze": "ANALYZE=true next build",
    "bundle:check": "node scripts/check-bundle-budget.js .next/analyze/bundle.json",
    "farm:generate": "node scripts/farm-agent.mjs",
    "farm:upload": "node scripts/farm-upload.mjs",
    "farm:pipeline": "node scripts/farm-pipeline.mjs",
    "farm:pipeline:publish": "UPLOAD_TO_SUPABASE=1 node scripts/farm-pipeline.mjs",
    "farm:pipeline:full": "UPLOAD_TO_SUPABASE=1 GITHUB_SYNC=1 node scripts/farm-pipeline.mjs",
    "prepare": "husky install",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@axe-core/react": "^4.9.0",
    "@base-ui/react": "^1.6.0",
    "@next/bundle-analyzer": "^15.5.20",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@sentry/nextjs": "^8.55.2",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "^15.5.20",
    "posthog-js": "^1.100.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.0",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.44.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.12",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse-ci": "^1.0.0",
    "prettier": "^3.2.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-config-tailwindcss": "^0.0.7",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.2",
    "typescript": "^5"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterSetup": [
      "<rootDir>/jest.setup.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/.next/",
      "<rootDir>/node_modules/",
      "<rootDir>/e2e/"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@/components/(.*)$": "<rootDir>/components/$1",
      "^@/lib/(.*)$": "<rootDir>/lib/$1",
      "^@/hooks/(.*)$": "<rootDir>/hooks/$1",
      "^@/types/(.*)$": "<rootDir>/types/$1"
    },
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": [
        "babel-jest",
        {
          "presets": [
            "next/babel"
          ]
        }
      ]
    },
    "collectCoverageFrom": [
      "components/**/*.{ts,tsx}",
      "lib/**/*.{ts,tsx}",
      "hooks/**/*.{ts,tsx}",
      "app/**/*.{ts,tsx}",
      "!app/**/*.d.ts",
      "!**/*.stories.tsx"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    },
    "testTimeout": 10000,
    "testMatch": [
      "**/__tests__/**/*.test.(ts|tsx)",
      "**/*.test.(ts|tsx)"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
